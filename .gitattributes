# Normaliza finales de línea: en el repo siempre LF, en el checkout local
# según la plataforma. Evita diffs ruidosos y avisos CRLF/LF en Windows.
* text=auto eol=lf

# Binarios: nunca tocar.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
